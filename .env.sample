# .env.sample — 复制为 .env 并填入实际值
# cp .env.sample .env

# ── OpenClaw 网关 ─────────────────────────────────────────────────────────────

# 网关 HTTP 地址（默认 127.0.0.1:18789，本机运行一般不用改）
OPENCLAW_HTTP=http://127.0.0.1:18789

# 网关 WebSocket 地址
OPENCLAW_WS=ws://127.0.0.1:18789

# 访问 Token（必填）
OPENCLAW_TOKEN=your-openclaw-token-here

# Agent 名称（HTTP fallback 用，默认 main）
OPENCLAW_AGENT=main

# 会话 Key（WS 模式用，默认 agent:main:main）
OPENCLAW_SESSION_KEY=agent:main:main

# ── OpenClaw Hub（可选） ───────────────────────────────────────────────────────

# Hub WebSocket 地址，留空则不连接 Hub
OPENCLAW_HUB_WS=ws://mamclaw.com:9000/ws

# 在 Hub 上显示的名字和头像
OPENCLAW_HUB_NAME=我的龙虾
OPENCLAW_HUB_AVATAR=🦞
