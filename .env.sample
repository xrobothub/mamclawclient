# .env.sample
# 复制为 .env 后填写：cp .env.sample .env

# ── OpenClaw Gateway (required) ─────────────────────────────────────────────
OPENCLAW_HTTP=http://127.0.0.1:18789
OPENCLAW_WS=ws://127.0.0.1:18789
OPENCLAW_TOKEN=your-openclaw-token
OPENCLAW_AGENT=main
OPENCLAW_SESSION_KEY=agent:main:main

# ── OpenIM Client (Python side) ─────────────────────────────────────────────
# openim_client.py polls localhost bridge and forwards messages to main handler.
IM_ENABLED=0
IM_POLL_INTERVAL=3
IM_API_ADDR=http://47.239.0.170:10002
IM_CHAT_ADDR=http://47.239.0.170:10008

# Optional direct OpenIM credentials (mainly fallback / shared defaults)
IM_EMAIL=your-email@example.com
IM_PASSWORD=your-password
IM_USER_ID=
IM_TOKEN=
IM_PLATFORM_ID=3

# ── OpenIM SDK Bridge (Node) ────────────────────────────────────────────────
# openim_client.py <-> bridge over localhost HTTP
OPENIM_USE_BRIDGE=1
OPENIM_BRIDGE_URL=http://127.0.0.1:8788

# Bridge listen address
OPENIM_BRIDGE_HOST=127.0.0.1
OPENIM_BRIDGE_PORT=8788

# Bridge SDK endpoints
OPENIM_BRIDGE_IM_API=http://47.239.0.170:10002
OPENIM_BRIDGE_IM_WS=ws://47.239.0.170:10001
OPENIM_BRIDGE_CHAT_API=http://47.239.0.170:10008
OPENIM_BRIDGE_PLATFORM_ID=5

# Bridge auth (choose one mode)
# Mode A: static token
OPENIM_BRIDGE_USER_ID=your-openim-user-id
OPENIM_BRIDGE_TOKEN=
# Mode B: auto-login when token is empty
OPENIM_BRIDGE_EMAIL=your-email@example.com
OPENIM_BRIDGE_PASSWORD=your-password

# Bridge behavior
# 0 = no active pull (callback-only), 1 = active SDK conversation pull
OPENIM_BRIDGE_ACTIVE_POLL=0
OPENIM_BRIDGE_PULL_INTERVAL_MS=3000

# Bridge logs
# SDK log level: Silent=5, Error=4, Warn=3, Info=2, Debug=1, Trace=0
OPENIM_BRIDGE_SDK_LOG_LEVEL=5
# 1 = print each newly detected incoming message, 0 = quiet
OPENIM_BRIDGE_LOG_RECV=0

# ── Optional Hub / Zulip ─────────────────────────────────────────────────────
OPENCLAW_HUB_ENABLED=0
OPENCLAW_HUB_WS=ws://mamclaw.com:9000/ws
OPENCLAW_HUB_NAME=Lobster
OPENCLAW_HUB_AVATAR=lobster

ZULIP_ENABLED=0
ZULIP_SITE=https://your-zulip.example.com
ZULIP_EMAIL=bot@example.com
ZULIP_API_KEY=your-zulip-api-key
ZULIP_LISTEN=pm,mention
ZULIP_PRESENCE=1
